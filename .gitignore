# Python venv (re-created by setup.bat)
venv/
.venv/
env/
.env

# Bytecode / build
__pycache__/
*.pyc
*.pyo
*.pyd
build/
dist/
*.egg-info/

# Editor / OS junk
.vscode/
.idea/
.DS_Store
Thumbs.db

# Auritus runtime artifacts (per-user, lives under %LOCALAPPDATA%\Auritus)
*.log
config.json

# PyInstaller / Inno Setup output
build/
dist/
*.spec.bak
installer-output/
Auritus-Setup-*.exe

# Vendored whisper.cpp source + CI-built Vulkan binaries (CI rebuilds these
# on tag; keep them out of git to avoid bloat)
third_party/
vendor/whisper-cpp/*.dll
vendor/whisper-cpp/*.exe
